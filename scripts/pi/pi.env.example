# HealthPass — Raspberry Pi (.env template)
# Copy to the app root as .env, then run `php artisan key:generate`.
# Production-ish settings for the always-on kiosk Pi. See docs/deployment-pi.md.

APP_NAME=HealthPass
APP_ENV=production
APP_KEY=
APP_DEBUG=false

# The kiosk browser MUST reach the app at http://localhost so navigator.serial
# (Web Serial) has a secure context — LAN IPs over http do NOT. Staff reach the
# same server over the LAN via the Pi's IP; that traffic just gets no Web Serial
# (staff pages don't need it). See docs/deployment-pi.md "Web Serial ...".
APP_URL=http://localhost

# Kiosk network gate (KioskAccess, D-27). The Pi-local defense shape reaches the
# kiosk from loopback (Chromium hits http://localhost/kiosk), so it must OPT IN to
# loopback trust here — the config default is false (fail-safe: a same-host reverse
# proxy can make every internet visitor look like 127.0.0.1, so loopback is only
# trusted where the deployment truly runs on loopback). The HOSTED internet deploy
# leaves ALLOW_LOOPBACK unset/false and relies on enrolled device tokens + nurse
# auth instead (see docs/deployment-pi.md §9). Never turn RESTRICT off in production.
HEALTHPASS_KIOSK_RESTRICT=true
HEALTHPASS_KIOSK_ALLOW_LOOPBACK=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# MariaDB on the Pi itself.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=healthpass
DB_USERNAME=healthpass
DB_PASSWORD=change-me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="healthpass@dhvsu.edu.ph"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
