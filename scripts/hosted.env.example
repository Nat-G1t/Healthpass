# HealthPass — Hosted internet deploy (.env template)
# Copy to the app root as .env on the PUBLIC server, then run
# `php artisan key:generate`. This is the single hosted HTTPS shape (web app +
# kiosk over https://<domain>). Do NOT copy the root .env.example onto a public
# box — it ships APP_DEBUG=true and no Secure-cookie flag (fine for local dev,
# dangerous on the internet). For the Raspberry Pi defense shape use
# scripts/pi/pi.env.example instead.

APP_NAME=HealthPass
APP_ENV=production
APP_KEY=
# NEVER true in production — a stack trace on any 500 leaks env values, queries,
# and file paths to the visitor.
APP_DEBUG=false
# Public HTTPS origin. Generated links (email verification, password reset) and
# the kiosk URL derive from this. HTTPS is a secure context, so Web Serial works.
APP_URL=https://healthpass.example.edu.ph

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Never 'debug' in production — debug logs can capture request payloads (PII).
LOG_LEVEL=warning

# ── Session / cookie security (HTTPS) ────────────────────────────────────────
# SESSION_SECURE_COOKIE=true makes the browser send the session + CSRF cookies
# ONLY over HTTPS. Without it (the config default is unset → not Secure), any
# accidental http:// request or an SSL-strip MITM transmits the cookie in clear,
# enabling session hijacking of nurse/director/admin accounts. This is the single
# most important delta from the local template. (The Pi stays unset/false because
# it serves the kiosk over plain http://localhost by design.)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Kiosk network gate (KioskAccess, D-27) ───────────────────────────────────
# The hosted shape has NO trusted loopback: a same-host reverse proxy makes every
# visitor look like 127.0.0.1, so loopback trust would open /kiosk/scan to the
# whole internet as a PII oracle. Leave ALLOW_LOOPBACK off (the config default is
# already false) and reach the kiosk only via enrolled device tokens + nurse auth.
HEALTHPASS_KIOSK_RESTRICT=true
HEALTHPASS_KIOSK_ALLOW_LOOPBACK=false
# IMPORTANT: also set trusted proxies to the REAL proxy IP(s) — never '*' — in
# bootstrap/app.php, or per-IP throttles and the kiosk gate see the proxy's IP
# for every request. See docs/deployment-pi.md §9 (reverse-proxy notes).

# MySQL/MariaDB on the hosted DB.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=healthpass
DB_USERNAME=healthpass
DB_PASSWORD=change-me

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Real mail on the hosted deploy (OTP + verification emails must actually send).
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.edu.ph
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="healthpass@dhvsu.edu.ph"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
